{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schema/trait-descriptor.schema.json",
  "title": "TraitDescriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trait_id",
    "version",
    "display_name",
    "required_tags",
    "preferred_tags",
    "mapping_policy",
    "inheritance",
    "fallback_policy"
  ],
  "properties": {
    "trait_id": {
      "type": "string",
      "description": "Unique trait identifier."
    },
    "version": {
      "type": "string",
      "description": "Trait descriptor version."
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable trait name."
    },
    "description": {
      "type": "string",
      "description": "Optional trait description."
    },
    "slot_role": {
      "type": "string",
      "description": "Semantic slot role used for mapping.",
      "default": "generic_attachment_role"
    },
    "required_tags": {
      "type": "array",
      "minItems": 1,
      "description": "Required semantic tags for valid attachment targets.",
      "items": {
        "$ref": "#/$defs/tag_requirement"
      }
    },
    "preferred_tags": {
      "type": "array",
      "description": "Preferred semantic tags used for ranking.",
      "items": {
        "$ref": "#/$defs/tag_requirement"
      }
    },
    "mapping_policy": {
      "$ref": "#/$defs/mapping_policy"
    },
    "compatibility_rules": {
      "type": "array",
      "description": "Optional compatibility requirements.",
      "items": {
        "$ref": "#/$defs/compat_rule"
      }
    },
    "geometry_constraints": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional geometric constraints.",
      "properties": {
        "min_surface_area": {
          "type": "number",
          "minimum": 0
        },
        "max_surface_area": {
          "type": "number",
          "minimum": 0
        },
        "min_elongation": {
          "type": "number",
          "minimum": 0
        },
        "min_branch_count": {
          "type": "integer",
          "minimum": 0
        },
        "requires_articulation": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "inheritance": {
      "$ref": "#/$defs/inheritance"
    },
    "fallback_policy": {
      "$ref": "#/$defs/fallback_policy"
    },
    "engine_hints": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional hints for mapping/scoring behavior.",
      "properties": {
        "semantic_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.55
        },
        "quality_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.5
        },
        "weights": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "w_semantic": {
              "type": "number",
              "minimum": 0,
              "default": 0.5
            },
            "w_morph": {
              "type": "number",
              "minimum": 0,
              "default": 0.35
            },
            "w_topo": {
              "type": "number",
              "minimum": 0,
              "default": 0.15
            }
          }
        }
      }
    }
  },
  "$defs": {
    "tag_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "min_prob"],
      "properties": {
        "tag": {
          "type": "string",
          "description": "Semantic tag name."
        },
        "min_prob": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum probability for the tag."
        }
      }
    },
    "mapping_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "top_k",
            "one_to_many",
            "distribution_transfer"
          ],
          "description": "How the trait maps to target candidates."
        },
        "k": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "normalize_weights": {
          "type": "boolean",
          "default": true
        },
        "decay_with_count": {
          "type": "boolean",
          "default": true
        },
        "max_targets": {
          "type": "integer",
          "minimum": 1,
          "default": 16
        }
      }
    },
    "compat_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "requires_anchor",
            "requires_joint",
            "disallow_internal_node"
          ]
        },
        "value": {
          "type": ["string", "number", "boolean", "null"]
        }
      }
    },
    "inheritance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "dominant",
            "recessive",
            "blend",
            "probabilistic",
            "resource_conserved"
          ]
        },
        "base_probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.5
        },
        "mutation_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.05
        },
        "intensity_range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number"
          },
          "default": [0.2, 1.0]
        }
      }
    },
    "fallback_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "allow_ai_synthesis",
        "allow_create_part",
        "allow_translation"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "create_attachment_part",
            "trait_translation",
            "hybrid",
            "skip_with_record"
          ]
        },
        "allow_ai_synthesis": {
          "type": "boolean"
        },
        "allow_create_part": {
          "type": "boolean"
        },
        "allow_translation": {
          "type": "boolean"
        },
        "max_created_parts": {
          "type": "integer",
          "minimum": 0,
          "default": 2
        }
      }
    }
  }
}
